# Local-only settings (never commit this file — use `.gitignore`; copy from `.env-local.example`).
# Standard AWS credential env vars for local CLI/terraform (omit if using SSO/instance role).

AWS_REGION=us-east-1

# --- Terraform remote state (S3 + DynamoDB locking) ----------------------------
# Same AWS account → staging vs production are separated by (1) different state object keys under
# the bucket and/or (2) optional per-environment buckets below, plus (3) different
# infra/terraform `-var-file` (environments/staging.tfvars vs production.tfvars) for runtime resources.
#
# AWS resource naming: booking20-<environment>-<resource> (examples below).
#
# Prefer explicit singleton OR per-env pairs (omit TF_REMOTE_STATE_BUCKET *_only* when using only *_STAGING/_PRODUCTION:
# github-actions-repo-config uses staging as TERRAFORM_STATE_BUCKET / TERRAFORM_LOCK_TABLE fallback for legacy CI vars).
TF_REMOTE_STATE_BUCKET=booking20-staging-terraform
TF_REMOTE_LOCK_TABLE=booking20-staging-terraform-locks
#
# Omit the two lines above and use only *_STAGING / *_PRODUCTION if you split buckets (staging fills default repo Variables).
# TF_REMOTE_STATE_BUCKET_STAGING=booking20-staging-terraform
# TF_REMOTE_STATE_BUCKET_PRODUCTION=booking20-prod-terraform
# TF_REMOTE_LOCK_TABLE_STAGING=booking20-staging-terraform-locks
# TF_REMOTE_LOCK_TABLE_PRODUCTION=booking20-prod-terraform-locks
#
# Prefix for state keys inside the bucket (default booking20 → booking20/staging/terraform.tfstate):
# TF_STATE_KEY_PREFIX=booking20
#
# Or legacy aliases read by scripts/render-backend-config.sh:
# AWS_S3_BUCKET_NAME=booking20-staging-terraform
# AWS_DYNAMODB_TABLE_PREFIX=booking20-staging-terraform   # derives lock booking20-staging-terraform-locks
#
# S3 bucket names must be globally unique DNS-style labels — hyphens only (no underscores).

# --- GitHub Actions (repository Variables / Secrets) — mirror TF_* for CI ----------------------------
# Variables: TERRAFORM_STATE_BUCKET, TERRAFORM_LOCK_TABLE, AWS_REGION (optional)
# Optional: TERRAFORM_STATE_BUCKET_{STAGING,PRODUCTION}, TERRAFORM_LOCK_TABLE_{STAGING,PRODUCTION},
#           TERRAFORM_STATE_KEY_PREFIX (default booking20; must match infra/tf-github-actions-iam terraform_state_key_prefix)
# Secrets: AWS_ROLE_TO_ASSUME_STAGING, AWS_ROLE_TO_ASSUME_PRODUCTION (role ARNs from IAM bootstrap — optional sync via scripts/sync-github-actions-repo-config.sh)
# AWS_ROLE_TO_ASSUME_STAGING=arn:aws:iam::012345678901:role/booking20-staging-github-deploy
# AWS_ROLE_TO_ASSUME_PRODUCTION=arn:aws:iam::012345678901:role/booking20-production-github-deploy
