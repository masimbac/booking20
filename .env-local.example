# Local-only settings (never commit this file — use `.gitignore`; copy from `.env-local.example`).
# Standard AWS credential env vars for local CLI/terraform (omit if using SSO/instance role).

AWS_REGION=us-east-1

# --- Terraform remote state (S3 + DynamoDB locking) ----------------------------
# Same AWS account → staging vs production are separated by (1) different state object keys under
# the bucket and/or (2) optional per-environment buckets below, plus (3) different
# infra/terraform `-var-file` (environments/staging.tfvars vs production.tfvars) for runtime resources.
#
# Prefer explicit Terraform backend names:
TF_REMOTE_STATE_BUCKET=your-org-booking-terraform-state
TF_REMOTE_LOCK_TABLE=your-org-booking-tf-lock
#
# Optional — per-environment buckets/locks inside one account (# application-environment-<resource>):
# TF_REMOTE_STATE_BUCKET_STAGING=booking20-staging-terraform
# TF_REMOTE_STATE_BUCKET_PRODUCTION=booking20-prod-terraform
# TF_REMOTE_LOCK_TABLE_STAGING=booking20-staging-terraform-lock
# TF_REMOTE_LOCK_TABLE_PRODUCTION=booking20-prod-terraform-lock
#
# Prefix for state keys inside the bucket (default booking): booking/<env>/terraform.tfstate → use booking20:
# TF_STATE_KEY_PREFIX=booking20
#
# Or legacy aliases read by scripts/render-backend-config.sh:
# AWS_S3_BUCKET_NAME=your-org-booking-terraform-state
# AWS_DYNAMODB_TABLE_PREFIX=booking20    # derives lock table "<prefix>-terraform-locks"
#
# S3 bucket names must be globally unique DNS-style labels — hyphens only (no underscores).

# --- GitHub Actions (repository Variables / Secrets) — mirror TF_* for CI ----------------------------
# Variables: TERRAFORM_STATE_BUCKET, TERRAFORM_LOCK_TABLE, AWS_REGION (optional)
# Optional: TERRAFORM_STATE_BUCKET_{STAGING,PRODUCTION}, TERRAFORM_LOCK_TABLE_{STAGING,PRODUCTION},
#           TERRAFORM_STATE_KEY_PREFIX (booking20 aligns state keys under your app name)
# Secrets: AWS_ROLE_TO_ASSUME_STAGING, AWS_ROLE_TO_ASSUME_PRODUCTION (role ARNs from IAM bootstrap — optional sync via scripts/sync-github-actions-repo-config.sh)
# AWS_ROLE_TO_ASSUME_STAGING=arn:aws:iam::012345678901:role/booking-github-deploy-staging
# AWS_ROLE_TO_ASSUME_PRODUCTION=arn:aws:iam::012345678901:role/booking-github-deploy-production
