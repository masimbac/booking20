# Copy to terraform.tfvars (gitignored). Underscores are invalid in standard S3 bucket DNS names — use hyphens.
#
# Per-environment backends (pattern booking20-<environment>-terraform + booking20-<environment>-terraform-locks), e.g. staging:
#   terraform apply -state=staging.tfstate
# Then copy to terraform-production.tfvars, set booking20-prod-terraform / booking20-prod-terraform-locks, and:
#   terraform apply -state=production.tfstate -var-file=terraform-production.tfvars
#
# One shared bucket for all envs is also valid (state keys differentiate envs) — see scripts/render-backend-config.sh.

aws_region        = "us-east-1"
state_bucket_name = "booking20-staging-terraform"
lock_table_name   = "booking20-staging-terraform-locks"
