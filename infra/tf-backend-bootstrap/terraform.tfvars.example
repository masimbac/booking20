# Copy to terraform.tfvars (gitignored). Use a hyphenated, globally unique bucket name —
# underscores are invalid for standard S3 bucket DNS names.

aws_region          = "us-east-1"
state_bucket_name   = "YOUR_ACCOUNT_OR_ORG_BOOKING_TF_STATE"
lock_table_name     = "YOUR_ACCOUNT_OR_ORG_BOOKING_TF_LOCK"
